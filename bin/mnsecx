#!/bin/bash

if [ -z "$1" ]; then
	echo "USAGE: $0 <HOST> <CMD> [ARGS ...]"
	exit 1
fi

HOST=$1
shift

HOST_PID=$(pgrep -f "bash.* mininet:$HOST$")

if ! echo "$HOST_PID" | egrep -q "^[0-9]+$"; then
	echo "Invalid host PID: $HOST_PID"
	echo "USAGE: $0 <HOST> <CMD> [ARGS ...]"
	exit 2
fi

if readlink /proc/$HOST_PID/exe | grep -q -w kubectl; then
	POD=$(cat /proc/$HOST_PID/cmdline | tr '\0' ' ' | cut -d' ' -f4,5,6)
	exec kubectl exec -i $POD -- $@
fi

mnexec -a $HOST_PID $@
